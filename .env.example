# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# --- EmailJS Configurations (Teams/Bonus Service) ---
VITE_EMAILJS_PUBLIC_KEY=""
VITE_EMAILJS_SERVICE_ID=""
VITE_EMAILJS_TEMPLATE_ID=""
VITE_EMAILJS_PRIVATE_KEY=""

# --- EmailJS Configurations (Auth/OTP Service) ---
VITE_EMAILJS_AUTH_PUBLIC_KEY=""
VITE_EMAILJS_AUTH_SERVICE_ID=""
VITE_EMAILJS_AUTH_TEMPLATE_ID=""
VITE_EMAILJS_AUTH_PRIVATE_KEY=""

# --- Cloudinary for Image Storage (NID/Profile) ---
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_API_KEY=""
VITE_CLOUDINARY_API_SECRET=""
VITE_CLOUDINARY_UPLOAD_PRESET=""

# --- LandingAI for NID OCR Extraction ---
VITE_LANDINGAI_API_KEY=""

# --- Firebase Configuration ---
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Firebase Admin Configuration (for cron job)
FIREBASE_SERVICE_ACCOUNT_KEY=""
